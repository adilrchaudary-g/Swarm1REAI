hermes/data/artifacts/exports/*.xlsx
!hermes/data/
!hermes/data/.gitkeep
!hermes/data/artifacts/
!hermes/data/artifacts/.gitkeep
!hermes/data/artifacts/exports/
!hermes/data/artifacts/exports/.gitkeep

