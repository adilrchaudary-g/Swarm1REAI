# =============================================================================
# SECRETS — never commit these
# =============================================================================
secrets/
secrets/*
!secrets/README.md
*.env
.env
.env.local
.env.*.local
*.token
*.key
*.pem
webhooks.txt
hermes-token.txt
propstream-cookies.txt

# =============================================================================
# Personally Identifying Information
# Skip-trace returns, owner contact data, exported lead lists. NEVER commit.
# =============================================================================
*-skiptrace.csv
*-skiptrace.json
*-skiptrace.xlsx
*-leads.csv
*-leads.json
*-leads.xlsx
exports/
downloads/
pii/
hermes/data/propstream.db
hermes/data/propstream.db-*
